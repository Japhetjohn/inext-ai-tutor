modules = ["web", "python-3.12", "nodejs-20"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Run"

[[workflows.workflow]]
name = "Run"
author = 42326293
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd web3Tutor && uvicorn back:app --host 0.0.0.0 --port 5000 --reload"

[[ports]]
localPort = 5000
externalPort = 80
